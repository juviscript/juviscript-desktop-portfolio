{
  "name": "juviscript-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "issues:create:post-mvp": "node .\\scripts\\create-post-mvp-issues.mjs",
    "issues:create:post-mvp:dry": "node .\\scripts\\create-post-mvp-issues.mjs --dry-run",
    "issues:seed": "node .\\scripts\\seed-github-issues.mjs",
    "issues:seed:dry": "node .\\scripts\\seed-github-issues.mjs --dry-run",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5",
    "wrangler": "^4.84.1"
  }
}
